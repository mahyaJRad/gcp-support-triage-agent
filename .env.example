# Copy to .env and fill in. NEVER commit .env.
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1

# BigQuery
BQ_SOURCE_TABLE=bigquery-public-data.stackoverflow
BQ_DATASET=support_triage          # your working dataset (created by `make ingest`)
BQ_SAMPLE_TAG=google-cloud-platform # which tag domain to scope the corpus to
BQ_SAMPLE_ROWS=3000                 # keep <= NL API free tier (5000 units/mo)
BQ_SAMPLE_PERCENT=5                 # TABLESAMPLE fraction; ~5% keeps ingest scan under 2 GB
BQ_GRAPH_NAME=triage_graph

# Vertex AI / Gemini
GEMINI_MODEL=gemini-2.5-flash       # Flash only for batch; never Pro
VERTEX_LOCATION=us-central1

# ADK -> Vertex AI backend (so the agent's Gemini calls go through Vertex, not a
# consumer API key). ADK reads these env vars directly.
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-project-id    # same as GCP_PROJECT_ID
GOOGLE_CLOUD_LOCATION=us-central1       # same as VERTEX_LOCATION

# Firestore (optional, Phase 2 memory)
FIRESTORE_COLLECTION=triage_sessions
